# 复制为 .env 并填入真实密钥
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/storyforge
REDIS_URL=redis://redis:6379/0
JWT_SECRET_KEY=change-this-to-a-random-string
JWT_EXPIRE_HOURS=24

# ---------- LLM ----------
LLM_API_KEY=sk-your-key-here
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-v4-flash
# LLM_PROXY=http://172.18.240.1:7897
# LLM_FALLBACK_MODELS=deepseek-chat,deepseek-reasoner

# ---------- Embedding (可选) ----------
# 不配则自动用 PostgreSQL 全文搜索
# EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
# EMBEDDING_MODEL=BAAI/bge-m3
# EMBEDDING_API_KEY=sk-xxx

