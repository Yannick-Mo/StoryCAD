# 复制为 .env 并填入真实密钥
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/storyforge
REDIS_URL=redis://redis:6379/0
JWT_SECRET_KEY=change-me-to-a-random-string
JWT_EXPIRE_HOURS=24

# ---------- LLM ----------
LLM_API_KEY=sk-xxx
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
# Docker 容器内用 Docker bridge 网关 IP；本机请改为 127.0.0.1
# LLM_PROXY=http://172.18.240.1:7897

# ---------- Embedding (可选) ----------
# 不配则自动用 PostgreSQL 全文搜索
# EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
# EMBEDDING_MODEL=BAAI/bge-m3
# EMBEDDING_API_KEY=sk-xxx

# ---------- 搜索 ----------
# SearXNG 地址 (Docker Compose 内部网络使用服务名)
# SEARXNG_URL=http://searxng:8080
# 搜索结果数量上限
# SEARCH_MAX_RESULTS=10
# 是否启用 DuckDuckGo 回退 (SearXNG 不可用时)
# SEARCH_ENABLE_DDG_FALLBACK=true
# SerpAPI key (可选升级，配置后优先于 SearXNG)
# SERPAPI_API_KEY=

# ---------- 网页抓取 ----------
# 单次抓取最大字符数
# WEB_FETCH_MAX_CHARS=50000
# 抓取超时秒数
# WEB_FETCH_TIMEOUT=15

